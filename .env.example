# ═══════════════════════════════════════════════════════════════
# CEDGYM — Environment variables
# Copy to .env for local dev. In production these come from Dokploy.
# ═══════════════════════════════════════════════════════════════

# ─── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://cedgym:cedgym_dev_pass@localhost:5432/cedgym?schema=public
POSTGRES_DB=cedgym
POSTGRES_USER=cedgym
POSTGRES_PASSWORD=cedgym_dev_pass

# ─── Redis ─────────────────────────────────────────────────────
# REDIS_PASSWORD is REQUIRED. The redis container refuses to start
# without it (--requirepass). For local dev, generate one with:
#   openssl rand -hex 32
REDIS_PASSWORD=change-me-redis-pass-min-32-chars-openssl-rand-hex-32
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379

# ─── API ───────────────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
API_PUBLIC_URL=http://localhost:3001
NODE_ENV=development
LOG_LEVEL=info

# JWT
JWT_SECRET=change-me-ultra-secret-256-bits-for-local-dev-only
JWT_REFRESH_SECRET=change-me-another-secret-for-refresh-tokens
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ─── Stripe (use TEST keys: sk_test_... / pk_test_... in dev) ─
# Live keys live ONLY in Dokploy / production secret manager. Never commit.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Price IDs from Stripe Dashboard → Products. Currency must be MXN.
STRIPE_PRICE_STARTER_MONTHLY=price_xxx
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_ELITE_MONTHLY=price_xxx
STRIPE_PRICE_MEAL_PLAN_ADDON=price_xxx

# ─── WhatsApp bot ──────────────────────────────────────────────
WHATSAPP_BOT_PORT=3002
WHATSAPP_BOT_URL=http://localhost:3002
WHATSAPP_BOT_KEY=change-me-whatsapp-bot-api-key
WHATSAPP_BOT_DATA_PATH=./apps/whatsapp-bot/.wwebjs_auth

# ─── Frontend ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ─── Twilio (fallback SMS - opcional) ──────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE=

# ─── Firebase (push - opcional) ────────────────────────────────
# FIREBASE_PROJECT_ID=
# FIREBASE_PRIVATE_KEY=

# ─── Observabilidad (opcional) ─────────────────────────────────
# SENTRY_DSN=
# POSTHOG_KEY=

# ─── MinIO (archivos) ──────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ROOT_USER=cedgym
MINIO_ROOT_PASSWORD=cedgym_minio_dev_pass
MINIO_BUCKET=cedgym
