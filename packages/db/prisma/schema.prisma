// ════════════════════════════════════════════════════════════════
//  CEDGYM — Prisma schema (fuente única compartida por API + bot)
// ════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ────────────────────────────────────────────────────────────────
// Enums
// ────────────────────────────────────────────────────────────────
enum Role {
  SUPERADMIN
  ADMIN
  RECEPTIONIST
  ATHLETE
}

enum UserStatus {
  UNVERIFIED
  ACTIVE
  SUSPENDED
  DELETED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_SAY
}

enum PlanType {
  STARTER
  PRO
  ELITE
}

enum MembershipPlan {
  STARTER
  PRO
  ELITE
}

enum MembershipStatus {
  TRIAL
  ACTIVE
  EXPIRED
  SUSPENDED
  CANCELED
}

enum BillingCycle {
  MONTHLY
}

enum Sport {
  FOOTBALL
  BOXING
  MMA
  POWERLIFTING
  CROSSFIT
  WEIGHTLIFTING
  GENERAL_FITNESS
  RUNNING
  NUTRITION
  OTHER
}

enum CheckInMethod {
  QR
  MANUAL
  BIOMETRIC
}

enum PaymentType {
  MEMBERSHIP
  COURSE
  DIGITAL_PRODUCT
  SUPPLEMENT
  MEAL_PLAN_ADDON
  OTHER
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
  CANCELED
}

enum JobStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

enum OtpPurpose {
  REGISTER
  PASSWORD_RESET
  PASSWORD_RESET_LINK
  LOGIN_2FA
  PHONE_CHANGE
}

enum DigitalProductType {
  ROUTINE
  NUTRITION_PLAN
  EBOOK
  VIDEO_COURSE
  BUNDLE
}

enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ALL_LEVELS
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum MuscleGroup {
  CHEST
  BACK
  LEGS
  SHOULDERS
  ARMS
  CORE
  FULL_BODY
  CARDIO
}

enum ExerciseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum FitnessGoal {
  WEIGHT_LOSS
  MUSCLE_GAIN
  MAINTENANCE
  STRENGTH
  ENDURANCE
  GENERAL_FITNESS
}

enum RoutineLocation {
  GYM
  HOME
  BOTH
}

enum RoutineSource {
  AI_GENERATED
  ADMIN_CREATED
  TEMPLATE_ASSIGNED
}

enum MealPlanSource {
  AI_GENERATED
  ADMIN_CREATED
}

enum MealType {
  BREAKFAST
  SNACK_AM
  LUNCH
  SNACK_PM
  DINNER
}

enum AIGenerationKind {
  ROUTINE
  MEAL_PLAN
  REGENERATION
}

// ────────────────────────────────────────────────────────────────
// Core multi-tenant
// ────────────────────────────────────────────────────────────────
model Workspace {
  id         String   @id @default(cuid())
  slug       String   @unique
  name       String
  logo_url   String?
  plan       PlanType @default(STARTER)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  users         User[]
  memberships   Membership[]
  check_ins     CheckIn[]
  courses       Course[]
  payments      Payment[]
  products      DigitalProduct[]
  whatsapp_sessions WhatsAppSession[]
  qr_tokens     QRToken[]
  meal_plan_addons  MealPlanAddon[]
  settings      WorkspaceSetting[]

  @@map("workspaces")
}

// ────────────────────────────────────────────────────────────────
// Generic key/value settings store — per-workspace.
//
// Used as the single source of truth for admin-editable pricing
// knobs that don't deserve their own structured table:
//
//   • plan.overrides           → { STARTER: { monthly_price_mxn?, quarterly_price_mxn?,
//                                             annual_price_mxn?, enabled? }, PRO: {...}, ELITE: {...} }
//     Merged into PLAN_CATALOG at read time (lib/memberships.js).
//
//   • meal_plan_addon.price_mxn → integer. Overrides the hardcoded
//                                 $499 in routes/addons.js.
//
// `value` is JSON to keep the table flexible (numbers, strings,
// nested objects) without a migration per new key.
// ────────────────────────────────────────────────────────────────
model WorkspaceSetting {
  id           String   @id @default(cuid())
  workspace_id String
  key          String
  value        Json
  updated_by   String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@unique([workspace_id, key])
  @@index([workspace_id])
  @@map("workspace_settings")
}

model User {
  id                String     @id @default(cuid())
  workspace_id      String
  name              String
  full_name         String?
  email             String?    @unique
  phone             String?    @unique
  birth_date        DateTime?
  gender            Gender?
  role              Role       @default(ATHLETE)
  password_hash     String
  avatar_url        String?
  selfie_url        String?
  status            UserStatus @default(UNVERIFIED)
  phone_verified_at DateTime?
  email_verified_at DateTime?
  profile_completed Boolean    @default(false)
  last_login_at     DateTime?
  fitness_profile   Json?
  // Set the first time the user pays the one-time inscription fee
  // (charged on first PRO/ELITE subscription). Existing users at
  // cutover are backfilled to NOW() so they're exempt.
  inscription_paid_at DateTime?
  // Login lockout — incremented on each failed /auth/login, reset
  // on success. When >=5, locked_until is set 15min ahead and the
  // counter resets. Generic 401 either way (no enumeration leak).
  failed_login_attempts Int      @default(0)
  locked_until        DateTime?
  // MFA (TOTP) — groundwork. mfa_enabled false means no second factor
  // is enforced; once true the login flow demands a 6-digit code.
  // mfa_recovery_codes are bcrypt-hashed at enrollment.
  mfa_secret          String?
  mfa_enabled         Boolean    @default(false)
  mfa_recovery_codes  String[]   @default([])
  created_at        DateTime   @default(now())
  updated_at        DateTime   @updatedAt

  workspace          Workspace          @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  membership         Membership?
  check_ins          CheckIn[]
  payments           Payment[]
  emergency_contacts EmergencyContact[]
  authored_products  DigitalProduct[]   @relation("AuthoredProducts")
  product_purchases  ProductPurchase[]
  product_reviews    ProductReview[]
  refresh_tokens     RefreshToken[]
  routines           Routine[]
  mealPlans          MealPlan[]
  ai_generations     AIGeneration[]
  meal_plan_addons   MealPlanAddon[]

  @@index([workspace_id])
  @@index([phone])
  @@map("users")
}

model EmergencyContact {
  id           String   @id @default(cuid())
  user_id      String
  name         String
  relationship String
  phone        String
  is_primary   Boolean  @default(true)
  created_at   DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("emergency_contacts")
}

model RefreshToken {
  id         String   @id @default(cuid())
  user_id    String
  token_hash String   @unique
  expires_at DateTime
  revoked_at DateTime?
  user_agent String?
  ip_address String?
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("refresh_tokens")
}

// ────────────────────────────────────────────────────────────────
// OTP (WhatsApp)
// ────────────────────────────────────────────────────────────────
model OtpCode {
  id           String     @id @default(cuid())
  phone        String
  code_hash    String
  purpose      OtpPurpose
  attempts     Int        @default(0)
  max_attempts Int        @default(5)
  expires_at   DateTime
  verified_at  DateTime?
  created_at   DateTime   @default(now())

  @@index([phone, purpose])
  @@map("otp_codes")
}

// ────────────────────────────────────────────────────────────────
// Membership
// ────────────────────────────────────────────────────────────────
model Membership {
  id                 String           @id @default(cuid())
  workspace_id       String
  user_id            String           @unique
  plan               MembershipPlan
  sport              Sport?
  status             MembershipStatus @default(TRIAL)
  starts_at          DateTime
  expires_at         DateTime
  price_mxn          Int
  billing_cycle      BillingCycle     @default(MONTHLY)
  mp_subscription_id String?
  auto_renew         Boolean          @default(true)
  created_at         DateTime         @default(now())
  updated_at         DateTime         @updatedAt

  workspace Workspace          @relation(fields: [workspace_id], references: [id])
  user      User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  freezes   MembershipFreeze[]

  @@index([workspace_id, status])
  @@index([expires_at])
  @@map("memberships")
}

model MembershipFreeze {
  id            String   @id @default(cuid())
  membership_id String
  user_id       String
  reason        String
  starts_at     DateTime
  ends_at       DateTime
  days_frozen   Int
  approved_by   String?
  created_at    DateTime @default(now())

  membership Membership @relation(fields: [membership_id], references: [id], onDelete: Cascade)

  @@index([membership_id])
  @@map("membership_freezes")
}

// ────────────────────────────────────────────────────────────────
// Check-in / QR
// ────────────────────────────────────────────────────────────────
model CheckIn {
  id           String        @id @default(cuid())
  workspace_id String
  user_id      String
  method       CheckInMethod @default(QR)
  scanned_at   DateTime      @default(now())
  staff_id     String?

  workspace Workspace @relation(fields: [workspace_id], references: [id])
  user      User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([workspace_id, scanned_at])
  @@index([user_id, scanned_at])
  @@map("check_ins")
}

model QRToken {
  id           String   @id @default(cuid())
  workspace_id String
  token        String   @unique
  expires_at   DateTime
  user_id      String?
  created_at   DateTime @default(now())

  workspace Workspace @relation(fields: [workspace_id], references: [id])

  @@index([token])
  @@map("qr_tokens")
}

// ────────────────────────────────────────────────────────────────
// Courses & bookings
// ────────────────────────────────────────────────────────────────
model Course {
  id           String   @id @default(cuid())
  workspace_id String
  name         String
  description  String?  @db.Text
  sport        Sport
  trainer_id   String
  capacity     Int
  enrolled     Int      @default(0)
  price_mxn    Int
  starts_at    DateTime
  ends_at      DateTime
  schedule     Json
  published    Boolean  @default(false)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspace_id], references: [id])

  @@index([workspace_id])
  @@map("courses")
}

// ────────────────────────────────────────────────────────────────
// Payments (Mercado Pago)
// ────────────────────────────────────────────────────────────────
model Payment {
  id               String        @id @default(cuid())
  workspace_id     String
  user_id          String
  amount           Int
  type             PaymentType
  reference        String?
  description      String?
  mp_payment_id    String?       @unique
  mp_preference_id String?       @unique
  mp_status_detail String?
  status           PaymentStatus @default(PENDING)
  metadata         Json?
  paid_at          DateTime?
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt

  workspace Workspace @relation(fields: [workspace_id], references: [id])
  user      User      @relation(fields: [user_id], references: [id])

  @@index([workspace_id, status])
  @@index([user_id])
  @@map("payments")
}

model PromoCode {
  id             String       @id @default(cuid())
  workspace_id   String
  code           String       @unique
  type           DiscountType
  value          Int
  applies_to     String[]
  max_uses       Int?
  used_count     Int          @default(0)
  expires_at     DateTime?
  min_amount_mxn Int?
  enabled        Boolean      @default(true)
  created_at     DateTime     @default(now())

  @@map("promo_codes")
}

// ────────────────────────────────────────────────────────────────
// Marketplace (rutinas, nutrición, ebooks)
// ────────────────────────────────────────────────────────────────
model DigitalProduct {
  id             String             @id @default(cuid())
  workspace_id   String
  type           DigitalProductType
  title          String
  slug           String
  description    String             @db.Text
  cover_url      String?
  sport          Sport?
  level          Level              @default(ALL_LEVELS)
  duration_weeks Int?
  price_mxn      Int
  sale_price_mxn Int?
  author_id      String
  revenue_split  Int                @default(70)
  content        Json
  pdf_url        String?
  video_urls     String[]
  published      Boolean            @default(false)
  featured       Boolean            @default(false)
  rating_avg     Float              @default(0)
  rating_count   Int                @default(0)
  sales_count    Int                @default(0)
  created_at     DateTime           @default(now())
  updated_at     DateTime           @updatedAt

  workspace Workspace         @relation(fields: [workspace_id], references: [id])
  author    User              @relation("AuthoredProducts", fields: [author_id], references: [id])
  purchases ProductPurchase[]
  reviews   ProductReview[]

  @@unique([workspace_id, slug])
  @@index([published, featured])
  @@map("digital_products")
}

model ProductPurchase {
  id                String    @id @default(cuid())
  workspace_id      String
  user_id           String
  product_id        String
  payment_id        String?
  price_paid_mxn    Int
  author_payout_mxn Int
  gym_revenue_mxn   Int
  access_granted_at DateTime  @default(now())
  expires_at        DateTime?
  downloaded_times  Int       @default(0)

  user    User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  product DigitalProduct @relation(fields: [product_id], references: [id])

  @@unique([user_id, product_id])
  @@index([workspace_id])
  @@map("product_purchases")
}

model ProductReview {
  id         String   @id @default(cuid())
  product_id String
  user_id    String
  rating     Int
  comment    String?  @db.Text
  created_at DateTime @default(now())

  product DigitalProduct @relation(fields: [product_id], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([product_id, user_id])
  @@map("product_reviews")
}

// ────────────────────────────────────────────────────────────────
// Automations / WhatsApp
// ────────────────────────────────────────────────────────────────
model Automation {
  id            String   @id @default(cuid())
  workspace_id  String
  name          String
  trigger       String
  filter        Json?
  delay_minutes Int      @default(0)
  action        String
  params        Json
  enabled       Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  jobs AutomationJob[]

  @@index([workspace_id, trigger])
  @@map("automations")
}

model AutomationJob {
  id            String    @id @default(cuid())
  workspace_id  String
  automation_id String
  trigger_event String
  context       Json
  scheduled_at  DateTime
  status        JobStatus @default(PENDING)
  attempts      Int       @default(0)
  result_data   Json?
  last_error    String?   @db.Text
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  automation Automation @relation(fields: [automation_id], references: [id], onDelete: Cascade)

  @@index([status, scheduled_at])
  @@index([workspace_id])
  @@map("automation_jobs")
}

model MessageTemplate {
  id           String   @id @default(cuid())
  workspace_id String
  code         String
  name         String
  body         String   @db.Text
  channel      String
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@unique([workspace_id, code])
  @@map("message_templates")
}

model WhatsAppSession {
  id             String    @id @default(cuid())
  workspace_id   String
  staff_id       String?
  phone_number   String?
  is_connected   Boolean   @default(false)
  initializing   Boolean   @default(false)
  last_heartbeat DateTime?
  last_ready_at  DateTime?
  paired_at      DateTime?
  disconnected_at DateTime?
  qr_data        String?   @db.Text
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspace_id], references: [id])

  @@unique([workspace_id])
  @@map("whatsapp_sessions")
}

// ────────────────────────────────────────────────────────────────
// Gamification
// ────────────────────────────────────────────────────────────────
model UserProgress {
  id                  String    @id @default(cuid())
  user_id             String    @unique
  xp                  Int       @default(0)
  level               Int       @default(1)
  current_streak_days Int       @default(0)
  longest_streak_days Int       @default(0)
  last_checkin_date   DateTime?
  total_checkins      Int       @default(0)

  badges UserBadge[]

  @@map("user_progress")
}

model Badge {
  id          String @id @default(cuid())
  code        String @unique
  name        String
  description String
  icon_url    String
  xp_reward   Int    @default(0)
  rarity      String @default("COMMON")

  users UserBadge[]

  @@map("badges")
}

model UserBadge {
  id        String   @id @default(cuid())
  user_id   String
  badge_id  String
  earned_at DateTime @default(now())

  progress UserProgress @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  badge    Badge        @relation(fields: [badge_id], references: [id])

  @@unique([user_id, badge_id])
  @@map("user_badges")
}

// ────────────────────────────────────────────────────────────────
// Body tracking
// ────────────────────────────────────────────────────────────────
model BodyMeasurement {
  id             String   @id @default(cuid())
  user_id        String
  measured_at    DateTime @default(now())
  weight_kg      Float?
  body_fat_pct   Float?
  muscle_mass_kg Float?
  chest_cm       Float?
  waist_cm       Float?
  hip_cm         Float?
  arm_cm         Float?
  thigh_cm       Float?
  notes          String?  @db.Text
  photo_urls     String[]
  taken_by       String?

  @@index([user_id, measured_at])
  @@map("body_measurements")
}

// ────────────────────────────────────────────────────────────────
// Internal chat
// ────────────────────────────────────────────────────────────────
model Conversation {
  id              String    @id @default(cuid())
  workspace_id    String
  user_ids        String[]
  last_message_at DateTime?
  created_at      DateTime  @default(now())

  messages Message[]

  @@map("conversations")
}

model Message {
  id              String    @id @default(cuid())
  conversation_id String
  sender_id       String
  body            String    @db.Text
  attachment_url  String?
  read_at         DateTime?
  created_at      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@index([conversation_id])
  @@map("messages")
}

// ────────────────────────────────────────────────────────────────
// Audit log (LFPDPPP)
// ────────────────────────────────────────────────────────────────
model AuditLog {
  id           String   @id @default(cuid())
  workspace_id String
  actor_id     String?
  action       String
  target_type  String?
  target_id    String?
  metadata     Json?
  ip_address   String?
  user_agent   String?
  created_at   DateTime @default(now())

  @@index([workspace_id, created_at])
  @@index([actor_id])
  @@map("audit_logs")
}

// ────────────────────────────────────────────────────────────────
// AI-powered routines & meal plans
// ────────────────────────────────────────────────────────────────
model Exercise {
  id                String        @id @default(cuid())
  workspace_id      String
  name              String
  slug              String
  muscle_group      MuscleGroup
  equipment         String[]
  level             ExerciseLevel
  video_url         String?
  thumbnail_url     String?
  description       String?       @db.Text
  default_sets      Int           @default(3)
  default_reps      String
  default_rest_sec  Int           @default(60)
  variant_easier_id String?
  variant_harder_id String?
  is_active         Boolean       @default(true)
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt

  variant_easier   Exercise?          @relation("ExerciseEasier", fields: [variant_easier_id], references: [id])
  easier_of        Exercise[]         @relation("ExerciseEasier")
  variant_harder   Exercise?          @relation("ExerciseHarder", fields: [variant_harder_id], references: [id])
  harder_of        Exercise[]         @relation("ExerciseHarder")
  routine_entries  RoutineExercise[]

  @@index([workspace_id])
  @@index([workspace_id, slug])
  @@map("exercises")
}

model Routine {
  id                String          @id @default(cuid())
  workspace_id      String
  user_id           String
  name              String
  goal              FitnessGoal
  location          RoutineLocation
  days_per_week     Int
  source            RoutineSource
  ai_generation_id  String?
  // Coach-Templates V1 tracking (FASE 2). Both columns are optional —
  // legacy / pre-flag routines stay NULL. The migration that adds these
  // columns lives in packages/db/prisma/migrations/<ts>_add_coach_templates_tracking
  // and is NOT applied automatically. See SCHEMA.md in coach-templates/.
  template_id            String?
  template_used_fallback Boolean? @default(false)
  is_active         Boolean         @default(true)
  started_at        DateTime        @default(now())
  ended_at          DateTime?
  created_at        DateTime        @default(now())
  updated_at        DateTime        @updatedAt

  user          User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  ai_generation AIGeneration? @relation(fields: [ai_generation_id], references: [id])
  days          RoutineDay[]

  @@index([workspace_id])
  @@index([user_id])
  @@map("routines")
}

model RoutineDay {
  id          String  @id @default(cuid())
  routine_id  String
  day_of_week Int
  title       String
  notes       String? @db.Text
  order_index Int

  routine   Routine           @relation(fields: [routine_id], references: [id], onDelete: Cascade)
  exercises RoutineExercise[]

  @@index([routine_id])
  @@map("routine_days")
}

model RoutineExercise {
  id                     String  @id @default(cuid())
  routine_day_id         String
  exercise_id            String?
  exercise_name_snapshot String
  video_url              String?
  sets                   Int
  reps                   String
  rest_sec               Int
  order_index            Int
  notes                  String? @db.Text

  routine_day RoutineDay @relation(fields: [routine_day_id], references: [id], onDelete: Cascade)
  exercise    Exercise?  @relation(fields: [exercise_id], references: [id])

  @@index([routine_day_id])
  @@map("routine_exercises")
}

model MealPlan {
  id               String         @id @default(cuid())
  workspace_id     String
  user_id          String
  name             String
  goal             FitnessGoal
  calories_target  Int
  protein_g        Int
  carbs_g          Int
  fats_g           Int
  restrictions     String[]
  source           MealPlanSource
  ai_generation_id String?
  // Coach-Templates V1 tracking. Same caveats as Routine.
  template_id            String?
  template_used_fallback Boolean? @default(false)
  is_active        Boolean        @default(true)
  started_at       DateTime       @default(now())
  ended_at         DateTime?
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt

  user          User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  ai_generation AIGeneration? @relation(fields: [ai_generation_id], references: [id])
  meals         Meal[]

  @@index([workspace_id])
  @@index([user_id])
  @@map("meal_plans")
}

model Meal {
  id            String   @id @default(cuid())
  meal_plan_id  String
  day_of_week   Int
  meal_type     MealType
  name          String
  description   String   @db.Text
  ingredients   String[]
  calories      Int
  protein_g     Int
  carbs_g       Int
  fats_g        Int
  prep_time_min Int?
  order_index   Int

  meal_plan MealPlan @relation(fields: [meal_plan_id], references: [id], onDelete: Cascade)

  @@index([meal_plan_id])
  @@map("meals")
}

model AIGeneration {
  id              String           @id @default(cuid())
  workspace_id    String
  user_id         String?
  kind            AIGenerationKind
  model           String
  input_tokens    Int              @default(0)
  output_tokens   Int              @default(0)
  cost_usd        Decimal          @default(0) @db.Decimal(10, 6)
  prompt_snapshot String           @db.Text
  response_raw    String           @db.Text
  success         Boolean          @default(true)
  error_message   String?          @db.Text
  duration_ms     Int?
  created_at      DateTime         @default(now())

  user       User?      @relation(fields: [user_id], references: [id])
  routines   Routine[]
  meal_plans MealPlan[]

  @@index([workspace_id, created_at])
  @@index([user_id])
  @@map("ai_generations")
}

// ────────────────────────────────────────────────────────────────
// Meal-plan add-on (one-time purchase, $499 MXN by default).
//
// Unlocks ONE extra AI meal plan generation for users whose
// membership tier doesn't include that feature (or who already
// burned their plan-included quota for the period). Lifecycle:
//   PENDING  → payment created but MP hasn't approved yet
//   ACTIVE   → paid, ready to be consumed
//   CONSUMED → user generated a meal plan that drew from this addon
//   EXPIRED  → optional manual sweep when expires_at is set
//   REFUNDED → MP refund/chargeback
// ────────────────────────────────────────────────────────────────
enum MealPlanAddonStatus {
  PENDING
  ACTIVE
  CONSUMED
  EXPIRED
  REFUNDED
}

model MealPlanAddon {
  id                       String              @id @default(cuid())
  workspace_id             String
  user_id                  String
  payment_id               String?             @unique
  price_mxn                Int
  paid_mxn                 Int
  promo_code_id            String?
  status                   MealPlanAddonStatus @default(PENDING)
  activated_at             DateTime?
  consumed_at              DateTime?
  consumed_by_meal_plan_id String?
  expires_at               DateTime?
  created_at               DateTime            @default(now())
  updated_at               DateTime            @updatedAt

  workspace Workspace @relation(fields: [workspace_id], references: [id])
  user      User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, status])
  @@index([workspace_id, status])
  @@map("meal_plan_addons")
}
